# Backend
FRONTEND_ORIGIN=http://localhost:5173
CONTACT_EMAIL=you@example.com

# OpenAQ v3 requires an API key in the X-API-Key header.
# Sign up: https://explore.openaq.org/register
OPENAQ_API_KEY=

# NASA FIRMS Area API requires a free MAP_KEY.
# Request one: https://firms.modaps.eosdis.nasa.gov/api/map_key/
NASA_FIRMS_MAP_KEY=
NASA_FIRMS_SOURCE=VIIRS_NOAA20_NRT

# Frontend
VITE_API_BASE_URL=http://localhost:8000
